{
  "name": "mizan-monorepo",
  "version": "1.0.0",
  "packageManager": "npm@10.9.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "npm exec --workspace apps/web prisma -- generate --schema prisma/schema.prisma",
    "db:validate": "npm exec --workspace apps/web prisma -- validate --schema prisma/schema.prisma",
    "db:push": "npm exec --workspace apps/web prisma -- db push --schema prisma/schema.prisma",
    "db:migrate:deploy": "npm exec --workspace apps/web prisma -- migrate deploy --schema prisma/schema.prisma",
    "db:seed:taxonomy": "npm exec --workspace apps/web tsx -- scripts/seed_taxonomy.ts",
    "db:seed:providers": "npm exec --workspace apps/web tsx -- scripts/seed_providers.ts",
    "sms:profile": "node apps/web/scripts/sms-import/profile.mjs",
    "sms:dry-run": "node apps/web/scripts/sms-import/dry-run.mjs",
    "sms:import": "node apps/web/scripts/sms-import/import.mjs"
  },
  "dependencies": {
    "anser": "^2.3.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "stacktrace-parser": "^0.1.11"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-gesture-handler": "2.31.1"
  }
}
