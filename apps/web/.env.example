# === Database (Supabase PostgreSQL) ===
# Connection pooler URL (for Prisma queries via PgBouncer)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection URL (for Prisma migrations)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

# === AI ===
GEMINI_API_KEY="your-gemini-api-key"

# === Public ===
NEXT_PUBLIC_APP_URL="https://your-vercel-domain.vercel.app"

# === Supabase Auth/Public Keys ===
# Found in Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# === OAuth Providers ===
# Configure Google and Apple providers in Supabase Dashboard > Authentication > Providers.
# The app code uses Supabase Auth, not NextAuth.
